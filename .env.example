# ============================================
# JAPAN 225 TRADING BOT - ENVIRONMENT CONFIG
# ============================================
# Copy this to .env and fill in your values
# NEVER commit .env to git

# --- IG Markets API ---
# Get credentials at https://labs.ig.com
IG_API_KEY=your_api_key_here
IG_USERNAME=your_username_here
IG_PASSWORD=your_password_here
IG_ACC_NUMBER=your_account_number_here
# "demo" for testing, "live" for real money
IG_ENV=demo

# --- Telegram Bot ---
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Send any message to your bot, then visit:
# https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
# Look for "chat":{"id":XXXXXXX}
TELEGRAM_CHAT_ID=your_chat_id_here

# --- Trading ---
TRADING_MODE=live
# true = extra verbose logging
DEBUG=false

# --- Web Dashboard (optional) ---
# Long random string used as Bearer token for dashboard auth
# Generate one: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
DASHBOARD_TOKEN=your_long_random_secret_here
